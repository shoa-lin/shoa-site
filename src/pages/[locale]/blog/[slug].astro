---
import { getCollection, type CollectionEntry } from "astro:content";
import ArticlePage from "../../../components/pages/ArticlePage.astro";
import { type Locale } from "../../../lib/i18n";

export async function getStaticPaths() {
  const entries = await getCollection("blog", ({ data }) => data.locale !== "zh" && data.translationStatus !== "draft");
  return entries.map((entry) => ({
    params: { locale: entry.data.locale, slug: entry.data.translationKey },
    props: { locale: entry.data.locale, entry },
  }));
}

interface Props { locale: Locale; entry: CollectionEntry<"blog"> }
const { locale, entry } = Astro.props;
---

<ArticlePage locale={locale} entry={entry} />
