---
import { getDictionary, localeMeta, locales, type Locale } from "../lib/i18n";
import { localizedPath } from "../lib/routes";

interface Props {
  locale: Locale;
  path: string;
  availableLocales?: Locale[];
}

const { locale, path, availableLocales = locales } = Astro.props;
const dictionary = getDictionary(locale);
---

<details class="language-menu">
  <summary aria-label={dictionary.language.menu}>
    <span class="language-menu__code" aria-hidden="true">{locale.toUpperCase()}</span>
    <span>{localeMeta[locale].label}</span>
  </summary>
  <div class="language-menu__popover" role="list" aria-label={dictionary.a11y.languageMenu}>
    {
      availableLocales.map((option) => (
        <a
          href={localizedPath(option, path)}
          lang={localeMeta[option].htmlLang}
          data-locale={option}
          role="listitem"
          aria-current={option === locale ? "page" : undefined}
        >
          <span>{localeMeta[option].label}</span>
          <span class="language-menu__code" aria-hidden="true">{option.toUpperCase()}</span>
        </a>
      ))
    }
  </div>
</details>

<script>
  import { isPreferredLocale, localePreferenceKey } from "../lib/locale-preference";

  document.addEventListener("click", (event) => {
    if (!(event.target instanceof Element)) return;

    const link = event.target.closest<HTMLAnchorElement>(".language-menu__popover a[data-locale]");
    const locale = link?.dataset.locale;
    if (!isPreferredLocale(locale)) return;

    try {
      localStorage.setItem(localePreferenceKey, locale);
    } catch {
      // Navigation remains available when browser storage is unavailable.
    }
  });
</script>
