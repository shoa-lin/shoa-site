---
import { getDictionary, type Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dictionary = getDictionary(locale);
---

<button
  class="theme-toggle icon-button"
  type="button"
  aria-label={dictionary.theme.toggle}
  title={dictionary.theme.toggle}
  data-theme-toggle
>
  <span class="theme-toggle__light" aria-hidden="true">☀</span>
  <span class="theme-toggle__dark" aria-hidden="true">☾</span>
</button>

<script is:inline>
  for (const button of document.querySelectorAll("[data-theme-toggle]")) {
    button.addEventListener("click", () => {
      const current = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      const next = current === "dark" ? "light" : "dark";
      document.documentElement.dataset.theme = next;
      localStorage.setItem("shoa-theme", next);
    });
  }
</script>
