---
interface Props {
  href: string;
  title: string;
  description: string;
  date: string;
  category: string;
  categoryKey?: string;
}

const { href, title, description, date, category, categoryKey } = Astro.props;
---

<article class="article-card" data-category={categoryKey}>
  <div class="article-card__meta">
    <time datetime={date}>{date}</time>
    <span>{category}</span>
  </div>
  <h2><a href={href}>{title}</a></h2>
  <p>{description}</p>
</article>
