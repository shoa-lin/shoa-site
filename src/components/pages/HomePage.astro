---
import ArticleCard from "../ArticleCard.astro";
import { getCollection } from "astro:content";
import { profile } from "../../data/profile";
import { getDictionary, localeMeta, type Locale } from "../../lib/i18n";
import { localizedPath } from "../../lib/routes";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props { locale: Locale }
const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const dateFormatter = new Intl.DateTimeFormat(localeMeta[locale].htmlLang, { dateStyle: "medium" });
const latestPublications = (await getCollection("blog", ({ data }) => (
  data.locale === locale
  && (data.translationStatus !== "draft" || (locale === "zh" && import.meta.env.DEV))
)))
  .sort((left, right) => right.data.publishedAt.valueOf() - left.data.publishedAt.valueOf())
  .slice(0, 3);
---

<BaseLayout locale={locale} path="/" description={dictionary.meta.siteDescription}>
  <section class="home-hero">
    <div class="home-hero__copy">
      <h1>{dictionary.home.greeting}</h1>
      <p class="home-hero__intro">{dictionary.home.intro}</p>
      <p class="home-hero__supporting">{dictionary.home.supporting}</p>
      <div class="inline-links">
        <a href={`mailto:${profile.email}`}>Email</a>
        <a href={profile.x} rel="me noopener noreferrer">X</a>
        <a href={profile.github} rel="me noopener noreferrer">GitHub</a>
      </div>
    </div>
    <div class="home-hero__portrait">
      <img src={profile.avatar} alt="Shoa Lin" width="320" height="320" />
    </div>
  </section>

  <section class="editorial-section editorial-split">
    <h2>{dictionary.home.interestsTitle}</h2>
    <p>{dictionary.home.interestsBody}</p>
  </section>

  <section class="editorial-section profile-notes">
    <article>
      <h2>{dictionary.home.backgroundTitle}</h2>
      <p>{dictionary.home.backgroundBody}</p>
    </article>
    <article>
      <h2>{dictionary.home.approachTitle}</h2>
      <p>{dictionary.home.approachBody}</p>
    </article>
  </section>

  <section class="editorial-section latest-writing">
    <div class="section-row-head">
      <h2>{dictionary.home.latestTitle}</h2>
      <a href={localizedPath(locale, "/blog")}>{dictionary.nav.blog}</a>
    </div>
    <div>
      {latestPublications.map((entry) => (
        <ArticleCard
          href={localizedPath(locale, `/blog/${entry.data.translationKey}`)}
          title={entry.data.title}
          description={entry.data.description}
          date={dateFormatter.format(entry.data.publishedAt)}
          category={dictionary.blog.categories[entry.data.category]}
        />
      ))}
    </div>
  </section>

  <section class="editorial-section contact-strip">
    <div>
      <h2>{dictionary.home.contactTitle}</h2>
      <p>{dictionary.home.contactBody}</p>
    </div>
    <a class="text-command" href={localizedPath(locale, "/contact")}>{dictionary.nav.contact}</a>
  </section>
</BaseLayout>
