---
import ArticleCard from "../ArticleCard.astro";
import { getCollection } from "astro:content";
import { getDictionary, localeMeta, type Locale } from "../../lib/i18n";
import { localizedPath } from "../../lib/routes";
import BlogIndexLayout from "../../layouts/BlogIndexLayout.astro";

interface Props { locale: Locale }
const { locale } = Astro.props;
const dictionary = getDictionary(locale);
const categories = Object.entries(dictionary.blog.categories);
const dateFormatter = new Intl.DateTimeFormat(localeMeta[locale].htmlLang, { dateStyle: "medium" });
const entries = (await getCollection("blog", ({ data }) => data.locale === locale && data.translationStatus !== "draft"))
  .sort((left, right) => right.data.publishedAt.valueOf() - left.data.publishedAt.valueOf());
const legacyRoutes = Object.fromEntries(entries.map((entry) => [
  entry.data.translationKey,
  localizedPath(locale, `/blog/${entry.data.translationKey}`),
]));
---

<BlogIndexLayout locale={locale} path="/blog" title={dictionary.blog.title} description={dictionary.blog.description}>
  <header class="page-intro page-intro--compact">
    <h1>{dictionary.blog.title}</h1>
    <p>{dictionary.blog.description}</p>
  </header>
  <nav class="filter-row" aria-label={dictionary.blog.title}>
    <a href={localizedPath(locale, "/blog")} aria-current="page">{dictionary.blog.all}</a>
    {categories.map(([key, label]) => <a href={`${localizedPath(locale, "/blog")}?category=${key}`}>{label}</a>)}
  </nav>
  <div class="blog-list-quiet">
    {entries.map((entry) => (
      <ArticleCard
        href={localizedPath(locale, `/blog/${entry.data.translationKey}`)}
        title={entry.data.title}
        description={entry.data.description}
        date={dateFormatter.format(entry.data.publishedAt)}
        category={dictionary.blog.categories[entry.data.category]}
      />
    ))}
    {entries.length === 0 && <p class="collection-empty">{dictionary.blog.empty}</p>}
  </div>
  <script is:inline define:vars={{ legacyRoutes }}>
    const legacyId = new URLSearchParams(window.location.search).get("id");
    if (legacyId && legacyRoutes[legacyId]) window.location.replace(legacyRoutes[legacyId]);
  </script>
</BlogIndexLayout>
